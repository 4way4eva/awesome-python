*filter
:INPUT DROP [0:0]
:FORWARD DROP [0:0]
:OUTPUT ACCEPT [0:0]

# Allow established traffic and loopback
-A INPUT -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT
-A INPUT -i lo -j ACCEPT

# Allow ICMP for diagnostics and PMTU discovery
-A INPUT -p icmp -j ACCEPT

# Required services
-A INPUT -p tcp --dport 22 -m conntrack --ctstate NEW -j ACCEPT
-A INPUT -p tcp --dport 80 -m conntrack --ctstate NEW -j ACCEPT
-A INPUT -p tcp --dport 443 -m conntrack --ctstate NEW -j ACCEPT

# Optional: rate-limit common abuse vectors
-A INPUT -p tcp --syn --dport 80 -m limit --limit 25/second --limit-burst 100 -j ACCEPT
-A INPUT -p tcp --syn --dport 443 -m limit --limit 25/second --limit-burst 100 -j ACCEPT

# Log and drop remainder
-A INPUT -m limit --limit 5/min -j LOG --log-prefix "iptables-denied: " --log-level 7
-A INPUT -j DROP

COMMIT
